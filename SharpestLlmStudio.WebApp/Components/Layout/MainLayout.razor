@inherits LayoutComponentBase
@using SharpestLlmStudio.Shared
@inject IJSRuntime JS
@inject WebAppSettings Settings

<div class="layout-shell @(isResizing ? "resizing" : string.Empty)"
     @onmousemove="HandleResizeMouseMove"
     @onmouseup="StopResizing"
     @onmouseleave="StopResizing">
    <RadzenLayout>
        <RadzenHeader>
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem" class="rz-p-2">
                <RadzenSidebarToggle Click="ToggleSidebar" />
                <RadzenText TextStyle="TextStyle.H5" class="rz-mb-0" Text="SharpestLlmStudio" />
                @if (!sidebarExpanded)
                {
                    <RadzenBadge Text="@($"({sidebarLogCount})")" BadgeStyle="BadgeStyle.Info" Variant="Variant.Flat" class="rz-ml-2" />
                }
                <div style="flex:1"></div>
                <RadzenButton Icon="@ThemeIcon"
                              Text="Theme"
                              Size="ButtonSize.Small"
                              Variant="Variant.Flat"
                              ButtonStyle="ButtonStyle.Light"
                              Click="ToggleDarkModeAsync"
                              title="Dark Mode umschalten (On/Off)" />
            </RadzenStack>
        </RadzenHeader>

        <RadzenSidebar @bind-Expanded="sidebarExpanded" style="@($"width:{sidebarWidthPx}px;")" class="app-sidebar">
            <div class="sidebar-content-root">
                <NavMenu SidebarExpanded="sidebarExpanded" LogCountChanged="OnLogCountChanged" />

                <div class="sidebar-theme-toggle">
                    <RadzenButton Icon="@ThemeIcon"
                                  Text="@(sidebarExpanded ? $"Theme: {DarkModeDisplayLabel}" : null)"
                                  Size="ButtonSize.Small"
                                  Variant="Variant.Flat"
                                  ButtonStyle="ButtonStyle.Light"
                                  Click="ToggleDarkModeAsync"
                                  title="Dark Mode umschalten (On/Off)" />
                </div>

                @if (sidebarExpanded)
                {
                    <div class="sidebar-resize-handle" @onmousedown="StartResizing" title="Sidebar-Breite ändern">
                        <RadzenIcon Icon="drag_indicator" />
                    </div>
                }
            </div>
        </RadzenSidebar>

        <RadzenBody>
            <div class="rz-p-4">
                @Body
            </div>
        </RadzenBody>
    </RadzenLayout>
</div>

@code {
    bool sidebarExpanded = true;
    bool isResizing = false;
    int sidebarWidthPx = 320;
    int sidebarLogCount = 0;
    string darkModeSetting = "off";
    bool isDarkModeActive;

    private string DarkModeDisplayLabel => this.isDarkModeActive ? "On" : "Off";

    private string ThemeIcon => this.isDarkModeActive ? "dark_mode" : "light_mode";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        string configuredMode = NormalizeDarkMode(this.Settings.DarkMode);
        this.darkModeSetting = configuredMode is "on" or "off" ? configuredMode : "off";

        try
        {
            string? stored = await this.JS.InvokeAsync<string?>("localStorage.getItem", "ui.darkMode.override");
            string normalizedStored = NormalizeDarkMode(stored);
            if (normalizedStored is "on" or "off")
            {
                this.darkModeSetting = normalizedStored;
            }
            else if (configuredMode == "auto")
            {
                bool prefersDark = await this.JS.InvokeAsync<bool>("sharpestNavMenu.getPrefersDarkMode");
                this.darkModeSetting = prefersDark ? "on" : "off";
            }
        }
        catch
        {
            if (configuredMode == "auto")
            {
                try
                {
                    bool prefersDark = await this.JS.InvokeAsync<bool>("sharpestNavMenu.getPrefersDarkMode");
                    this.darkModeSetting = prefersDark ? "on" : "off";
                }
                catch
                {
                }
            }
        }

        await this.ApplyDarkModeAsync();
        await this.InvokeAsync(this.StateHasChanged);
    }

    private void ToggleSidebar()
    {
        this.sidebarExpanded = !this.sidebarExpanded;
        this.isResizing = false;
    }

    private void StartResizing(MouseEventArgs _)
    {
        if (!this.sidebarExpanded)
        {
            return;
        }

        this.isResizing = true;
    }

    private void HandleResizeMouseMove(MouseEventArgs e)
    {
        if (!this.isResizing || !this.sidebarExpanded)
        {
            return;
        }

        this.sidebarWidthPx = Math.Clamp((int) e.ClientX, 260, 720);
    }

    private void StopResizing(MouseEventArgs _)
    {
        this.isResizing = false;
    }

    private Task OnLogCountChanged(int count)
    {
        this.sidebarLogCount = count;
        return Task.CompletedTask;
    }

    private async Task ToggleDarkModeAsync()
    {
        this.darkModeSetting = this.darkModeSetting == "on" ? "off" : "on";

        try
        {
            await this.JS.InvokeVoidAsync("localStorage.setItem", "ui.darkMode.override", this.darkModeSetting);
        }
        catch
        {
        }

        await this.ApplyDarkModeAsync();
    }

    private async Task ApplyDarkModeAsync()
    {
        bool dark = this.darkModeSetting == "on";

        this.isDarkModeActive = dark;
        await this.JS.InvokeVoidAsync("sharpestNavMenu.applyDarkMode", dark);
    }

    private static string NormalizeDarkMode(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "auto";
        }

        string mode = value.Trim().ToLowerInvariant();
        return mode is "on" or "off" or "auto" ? mode : "auto";
    }
}
