@inherits LayoutComponentBase

<RadzenLayout>
    <RadzenHeader>
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0" class="rz-p-2">
            <RadzenSidebarToggle Click="@(() => sidebarExpanded = !sidebarExpanded)" />
            <RadzenText TextStyle="TextStyle.H5" class="rz-mb-0 rz-ml-2" Text="SharpestLlmStudio" />
        </RadzenStack>
    </RadzenHeader>

    <RadzenSidebar @bind-Expanded="sidebarExpanded" style="width:250px;">
        <RadzenPanelMenu>
            <RadzenPanelMenuItem Text="Home" Path="" Icon="home" />
        </RadzenPanelMenu>
    </RadzenSidebar>

    <RadzenBody>
        <div class="rz-p-4">
            @Body
        </div>
    </RadzenBody>
</RadzenLayout>

@code {
    bool sidebarExpanded = true;
}
